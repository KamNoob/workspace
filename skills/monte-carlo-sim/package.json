{
  "name": "monte-carlo-sim",
  "version": "2.0.0",
  "description": "Hybrid Monte Carlo simulation engine with Rust/Go/Julia optimization (15-50x faster)",
  "main": "lib/simulator-hybrid.js",
  "bin": {
    "mc": "bin/mc-cli.js"
  },
  "scripts": {
    "test": "node tests/test.js",
    "build": "bash BUILD.sh",
    "build:rust": "cd rust && cargo build --release && cp target/release/mc-rust ../bin/mc-rust",
    "build:go": "cd go && go build -o ../bin/mc-go .",
    "build:julia": "chmod +x julia/monte-carlo.jl",
    "example:integral": "node bin/mc-cli.js integrate 'x*x' 0 1 --samples 100000",
    "example:integral:large": "node bin/mc-cli.js integrate 'x*x' 0 1 --samples 1000000",
    "example:pi": "node bin/mc-cli.js pi --samples 1000000",
    "example:portfolio": "node bin/mc-cli.js portfolio --iterations 10000",
    "example:probability": "node bin/mc-cli.js probability 'Math.random() > 0.7' --samples 100000"
  },
  "keywords": [
    "monte-carlo",
    "simulation",
    "probability",
    "numerical-integration",
    "statistics",
    "risk-modeling"
  ],
  "author": "Art",
  "license": "MIT"
}
