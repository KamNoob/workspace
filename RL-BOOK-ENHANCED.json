{
  "metadata": {
    "title": "Reinforcement Learning: An Introduction",
    "authors": ["Richard S. Sutton", "Andrew G. Barto"],
    "edition": "2nd Edition",
    "publisher": "MIT Press",
    "year": 2018,
    "pages": 548,
    "format": "Enhanced Knowledge Base (JSON)",
    "original_source": "https://mitpress.mit.edu/books/reinforcement-learning",
