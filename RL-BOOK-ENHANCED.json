  },
  "quick_reference": {
    "core_concepts": [
      {
        "name": "Agent-Environment Loop",
        "formula": "State → Action → Reward → Next State",
        "description": "Fundamental RL cycle"
      },
      {
        "name": "Value Function (State)",
        "formula": "v(s) = E[G_t | S_t = s]",
        "definition": "Expected return from state s",
        "variant": "v_π for policy π, v_* for optimal"
      },
      {
        "name": "Value Function (Action)",
        "formula": "q(s,a) = E[G_t | S_t = s, A_t = a]",
        "definition": "Expected return from state s taking action a"
      },
      {
        "name": "Policy",
        "formula": "π(a|s) = P(A_t = a | S_t = s)",
        "definition": "Probability distribution over actions in state s"
      },
      {
        "name": "Bellman Equation",
        "formula": "v_π(s) = Σ_a π(a|s) Σ_{s',r} p(s',r|s,a)[r + γv_π(s')]",
        "importance": "Foundation for DP and RL convergence"
      },
      {
        "name": "Bellman Optimality",
        "formula": "v_*(s) = max_a Σ_{s'} p(s'|s,a)[r + γv_*(s')]",
        "importance": "Basis for optimal control algorithms"
      }
    ],
    "three_main_approaches": [
      {
        "approach": "Tabular Methods",
        "applicable_to": "Small state spaces",
        "subcategories": [
          "Dynamic Programming (requires model)",
          "Monte Carlo (model-free, episode-based)",
          "Temporal Difference (model-free, bootstrap)"
        ]
      },
      {
        "approach": "Function Approximation",
        "applicable_to": "Large/continuous spaces",
        "subcategories": [
          "Linear: v(s,w) = w^T φ(s)",
          "Non-linear: Neural networks"
        ]
      },
      {
        "approach": "Policy Search",
        "applicable_to": "Direct policy optimization",
        "subcategories": [
          "Policy Gradient",
          "Evolutionary Strategies"
        ]
      }
    ]
  },
  "parts": [
    {
      "part_id": 1,
      "name": "Tabular Solution Methods",
      "chapters": [
        {
          "chapter": 1,
          "title": "Introduction",
          "topics": [
            "Trial-and-error learning",
            "Reward signal",
            "Delayed feedback",
            "Credit assignment problem",
            "Exploration vs Exploitation tradeoff"
          ],
          "key_definitions": {
            "agent": "Decision maker",
            "environment": "World providing states and rewards",
            "state": "Information available to agent",
            "action": "Choice available to agent",
            "reward": "Numerical feedback signal"
          },
          "parameters": {
            "discount_factor": "γ (0 ≤ γ ≤ 1)",
            "learning_rate": "α"
          },
          "classic_example": {
            "name": "Tic-Tac-Toe",
            "state": "Board configuration",
            "value": "Probability of winning from state",
            "learning": "Self-play with value bootstrapping"
          }
        },
        {
          "chapter": 2,
          "title": "Multi-Armed Bandits",
          "problem": "Choose from k actions without state transitions (stateless RL)",
          "algorithms": [
            {
              "name": "ε-greedy",
              "formula": "Pick argmax with prob (1-ε), random with ε",
              "pros": ["Simple", "Guaranteed exploration"],
              "cons": ["Wastes samples on random actions"]
            },
            {
              "name": "Optimistic Initial Values",
              "formula": "Start Q(a) high → encourages exploration",
              "pros": ["Automatic exploration"],
              "cons": ["Problem-dependent tuning"]
            },
            {
              "name": "Upper-Confidence-Bound (UCB)",
              "formula": "Pick argmax Q(a) + c√(ln t / N(a))",
              "pros": ["Principled approach"],
              "cons": ["Requires tuning c"]
            },
            {
              "name": "Gradient Bandit",
              "formula": "π(a) ∝ exp(H(a)); H updated via reward",
              "pros": ["Theoretical foundation"],
              "cons": ["More complex"]
            },
            {
              "name": "Thompson Sampling",
              "formula": "Sample from posterior of each arm",
              "pros": ["Adaptive, Bayesian"],
              "cons": ["Bayesian overhead"]
            }
          ],
          "incremental_update": "Q(a) ← Q(a) + (1/N) * (R - Q(a))"
        },
        {
          "chapter": 3,
          "title": "Finite Markov Decision Processes",
          "mdp_tuple": ["S (states)", "A (actions)", "P (transitions)", "R (rewards)", "γ (discount)"],
          "returns": {
            "discounted": "G_t = R_{t+1} + γR_{t+2} + γ²R_{t+3} + ...",
            "episodic": "Terminal state ends episode",
            "continuing": "No terminal state, γ < 1 for convergence"
          },
          "value_functions": [
            {
              "name": "State value under policy π",
              "formula": "v_π(s) = E_π[G_t | S_t = s]",
              "equation": "v_π(s) = Σ_a π(a|s) Σ_{s',r} p(s',r|s,a)[r + γv_π(s')]"
            },
            {
              "name": "Action value under policy π",
              "formula": "q_π(s,a) = E_π[G_t | S_t = s, A_t = a]"
            },
            {
              "name": "Relationship",
              "formula": "v_π(s) = Σ_a π(a|s) q_π(s,a)"
            },
            {
              "name": "Optimal state value",
              "formula": "v_*(s) = max_π v_π(s)"
            },
            {
              "name": "Optimal action value",
              "formula": "q_*(s,a) = max_π q_π(s,a)"
            }
          ]
        },
        {
          "chapter": 4,
          "title": "Dynamic Programming",
          "prerequisites": ["Full model (P, R known)"],
          "algorithms": [
            {
              "name": "Policy Evaluation (Prediction)",
              "description": "Compute v_π for given policy",
              "update": "V(s) ← Σ_a π(a|s) [R(s,a) + γ Σ_{s'} p(s'|s,a)V(s')]",
              "convergence": "Guaranteed if |γ| < 1"
            },
            {
              "name": "Policy Improvement",
              "description": "Greedily improve policy given values",
              "formula": "π'(s) = argmax_a Σ_{s'} p(s'|s,a)[R(s,a) + γV(s')]",
              "property": "Policy improvement theorem: v_π' ≥ v_π"
            },
            {
              "name": "Policy Iteration",
              "description": "Repeat Evaluate → Improve",
              "convergence": "Guaranteed to converge to optimal policy",
              "iterations": "Usually converges in few policy iterations"
            },
            {
              "name": "Value Iteration",
              "description": "Single backup combining both",
              "update": "V(s) ← max_a [R(s,a) + γ Σ_{s'} p(s'|s,a)V(s')]",
              "convergence": "Converges to v_* (fewer iterations, costly per backup)"
            },
            {
              "name": "Asynchronous Dynamic Programming",
              "variants": [
                "In-place updates (overwrite values)",
                "Prioritized sweeping (prioritize high-error states)",
                "Real-time DP (interleave with agent interaction)"
              ],
              "advantage": "More flexible than synchronous DP"
            }
          ]
        },
        {
          "chapter": 5,
          "title": "Monte Carlo Methods",
          "key_idea": "Learn from complete episodes (no model needed)",
          "algorithms": [
            {
              "name": "MC Prediction",
              "description": "Estimate v_π from samples",
              "method": "Average returns following state visits",
              "convergence": "Law of large numbers → v_π"
            },
            {
              "name": "First-Visit MC",
              "formula": "Average G_t first time s appears per episode"
            },
            {
              "name": "Every-Visit MC",
              "formula": "Average each occurrence of s in episode"
            },
            {
              "name": "MC Control",
              "steps": [
                "Policy Evaluation: MC prediction for π",
                "Policy Improvement: ε-greedy over Q",
                "Exploring Starts: ensure all (s,a) visited infinitely"
              ],
              "convergence": "Guaranteed with exploring starts"
            },
            {
              "name": "MC Control without Exploring Starts",
              "method": "Use ε-greedy exploration",
              "advantage": "No need to manually ensure exploring starts",
              "convergence": "Converges to ε-optimal policy"
            }
          ],
          "off_policy": {
            "name": "Importance Sampling",
            "idea": "Reweight returns by likelihood ratio",
            "formula": "G_t^weighted = (π(A_t|S_t)/μ(A_t|S_t)) × ... × G_t",
            "problem": "High variance",
            "solutions": ["Ordinary importance sampling", "Weighted importance sampling"],
            "coverage_requirement": "π(a|s) > 0 when μ(a|s) > 0"
          }
        },
        {
          "chapter": 6,
          "title": "Temporal Difference Learning",
          "key_idea": "Combines MC sampling + DP bootstrapping",
          "algorithms": [
            {
              "name": "TD(0) Prediction",
              "update": "V(S_t) ← V(S_t) + α[R_{t+1} + γV(S_{t+1}) - V(S_t)]",
              "td_error": "δ_t = R_{t+1} + γV(S_{t+1}) - V(S_t)",
              "convergence": "Converges to v_π with decaying α",
              "advantages": [
                "Lower variance than MC (bootstrap uses V estimate)",
                "Online learning (no waiting for episode end)",
                "Learn from incomplete episodes"
              ]
            },
            {
              "name": "Sarsa (On-Policy TD Control)",
              "update": "Q(S_t, A_t) ← Q(S_t, A_t) + α[R_{t+1} + γQ(S_{t+1}, A_{t+1}) - Q(S_t, A_t)]",
              "property": "Updates with actual next action (follows behavior policy)",
              "convergence": "Converges to optimal policy with ε-greedy"
            },
            {
              "name": "Q-Learning (Off-Policy TD Control)",
              "update": "Q(S_t, A_t) ← Q(S_t, A_t) + α[R_{t+1} + γ max_a Q(S_{t+1}, a) - Q(S_t, A_t)]",
              "property": "Updates with greedy next action (target policy learning)",
              "advantage": "Learns optimal policy while following exploratory behavior",
              "convergence": "Guaranteed to v_* under conditions"
            },
            {
              "name": "Double Q-Learning",
              "motivation": "Avoid maximization bias",
              "update": "Q(S_t, A_t) ← Q(S_t, A_t) + α[R_{t+1} + γQ(S_{t+1}, argmax_a Q'(S_{t+1}, a)) - Q(S_t, A_t)]",
              "method": "Separate networks for action selection and evaluation"
            },
            {
              "name": "Expected Sarsa",
              "update": "Q(S_t, A_t) ← Q(S_t, A_t) + α[R_{t+1} + γ Σ_a π(a|S_{t+1})Q(S_{t+1}, a) - Q(S_t, A_t)]",
              "property": "Smoother updates than Sarsa",
              "variance": "Intermediate between Sarsa and Q-Learning"
            }
          ]
        },
        {
          "chapter": 7,
          "title": "n-Step Bootstrapping",
          "spectrum": "Between MC (n=∞) and TD(1)",
          "algorithms": [
            {
              "name": "n-Step TD Returns",
              "formula": "G_t^(n) = R_{t+1} + γR_{t+2} + ... + γ^(n-1)R_{t+n} + γ^n V(S_{t+n})"
            },
            {
              "name": "n-Step Sarsa",
              "update": "Use G_t^(n) in place of single-step target"
            },
            {
              "name": "n-Step Q-Learning",
              "update": "Use G_t^(n) with max_a Q(S_{t+n}, a)"
            },
            {
              "name": "Tree Backup (Off-Policy n-step)",
              "advantage": "Avoids importance sampling",
              "method": "Tree of possible futures weighted by policy"
            },
            {
              "name": "TD(λ) - Eligibility Traces",
              "lambda_return": "G_t^λ = (1-λ) Σ_{n=1}^∞ λ^(n-1) G_t^(n)",
              "endpoints": {
                "lambda_0": "TD(0)",
                "lambda_1": "MC",
                "lambda_between": "Spectrum between TD and MC"
              },
              "elegibility_traces": "e(s) tracks relevance of states to current error"
            }
          ]
        },
        {
          "chapter": 8,
          "title": "Planning & Learning with Tabular Methods",
          "algorithms": [
            {
              "name": "Dyna-Q",
              "idea": "Learn model + values simultaneously",
              "steps": [
                "Real experience: Learn model P, R; update Q",
                "Simulated experience: Use model to generate trajectories; update Q"
              ],
              "pseudocode": [
                "For each real step:",
                "  - Observe s', r",
                "  - Update Q(s,a)",
                "  - Update model M(s,a) → (s', r)",
                "  - For κ simulated steps:",
                "    - Sample s, a from memory",
                "    - Use model: s' ← M(s,a)",
                "    - Update Q(s,a) ← Q(s,a) + α[r + γ max Q(s',a')]"
              ]
            },
            {
              "name": "Prioritized Sweeping",
              "idea": "Prioritize recently-changed state-actions",
              "benefit": "Faster convergence by focusing computation"
            }
          ]
        }
      ]
    },
    {
      "part_id": 2,
      "name": "Approximate Solution Methods",
      "chapters": [
        {
          "chapter": 9,
          "title": "On-Policy Approximation with Function Approximation",
          "problem": "Tabular fails for large/continuous spaces",
          "algorithms": [
            {
              "name": "Linear Function Approximation",
              "formula": "v̂(s,w) = w^T φ(s) = Σ_i w_i φ_i(s)",
              "features": "φ(s) = [φ_1(s), ..., φ_d(s)] are basis functions",
              "update": "w ← w + α[R - v̂(s,w)]∇v̂(s,w) = w + α[R - w^T φ]φ"
            },
            {
              "name": "Tile Coding (Coarse Coding)",
              "idea": "Tile state space with overlapping tiles",
              "feature": "1 if in tile, 0 otherwise",
              "advantage": "Generalization via overlap; resolution via tile count"
            },
            {
              "name": "Radial Basis Functions (RBF)",
              "formula": "φ_i(s) = exp(-(||s - c_i||^2 / (2σ_i^2)))",
              "property": "Smooth, local features"
            }
          ],
          "convergence": "Converges to local optimum if step size sufficient",
          "stability_warning": "May diverge if off-policy (deadly triad)"
        },
        {
          "chapter": 10,
          "title": "Episodic Semi-Gradient Methods",
          "algorithms": [
            {
              "name": "Semi-Gradient TD(0)",
              "update": "w ← w + α[R_{t+1} + γv̂(S_{t+1},w) - v̂(S_t,w)]∇v̂(S_t,w)",
              "note": "Not true gradient (bootstraps on estimated value), but often works"
            },
            {
              "name": "Semi-Gradient Sarsa",
              "update": "Q̂(s,a,w) ← Q̂(s,a,w) + α[R_{t+1} + γQ̂(S_{t+1},A_{t+1},w) - Q̂(S_t,A_t,w)]∇Q̂"
            },
            {
              "name": "Semi-Gradient Expected Sarsa",
              "update": "Similar to Sarsa but with expected action value"
            }
          ],
          "example_problem": {
            "name": "Mountain Car",
            "state": "Position, velocity",
            "action": "Push left / right / coast",
            "reward": "-1 per step",
            "goal": "Reach top of hill",
            "challenge": "Sparse reward, credit assignment",
            "solution": "Tile coding + FA exploits state generalization"
          }
        },
        {
          "chapter": 11,
          "title": "Off-Policy Methods with Approximation",
          "deadly_triad": {
            "components": [
              "Function Approximation",
              "Bootstrapping",
              "Off-Policy Learning"
            ],
            "problem": "Can diverge due to feedback loops through estimates",
            "solutions": [
              "Prioritized Experience Replay",
              "Importance Sampling Weights",
              "Gradient TD / TDC (true gradient, stable)"
            ]
          },
          "algorithms": [
            {
              "name": "Gradient TD (GTD)",
              "idea": "Use secondary weights to stabilize off-policy learning",
              "advantage": "Theoretically sound",
              "disadvantage": "Practical overhead"
            }
          ]
        },
        {
          "chapter": 12,
          "title": "Eligibility Traces with Function Approximation",
          "idea": "Combine advantages of n-step methods with λ-returns",
          "algorithms": [
            {
              "name": "Accumulating Trace",
              "formula": "e(s) ← γλe(s) + ∇v̂(S_t,w)",
              "update": "w ← w + αδe",
              "td_error": "δ = R - v̂(S_t, w) + γv̂(S_{t+1},w)"
            },
            {
              "name": "Replacing Trace",
              "formula": "e(s) ← γλe(s) ∨ ∇v̂(S_t,w)",
              "note": "Reset to 1 if visited",
              "advantage": "Reduces variance for RL"
            },
            {
              "name": "Dutch Traces",
              "formula": "e(s) ← λ(γe(s) + (1-γ)v̂(s)) + ∇v̂(S_t,w)",
              "property": "Interpolate eligibility decay"
            }
          ]
        }
      ]
    },
    {
      "part_id": 3,
      "name": "Policy Gradient Methods",
      "chapters": [
        {
          "chapter": 13,
          "title": "Policy Gradient Methods",
          "idea": "Learn policy π_θ directly (not via value function)",
          "algorithms": [
            {
              "name": "REINFORCE (Monte Carlo Policy Gradient)",
              "update": "θ ← θ + α ∇ ln π(A_t|S_t,θ) G_t",
              "with_baseline": "θ ← θ + α ∇ ln π(A_t|S_t,θ) (G_t - b(S_t))",
              "baseline_choice": "Often v̂(s) used as baseline",
              "advantage": "Reduces variance without bias"
            },
            {
              "name": "Actor-Critic",
              "idea": "Combine policy (actor) + value (critic)",
              "critic_update": "w ← w + α[R + γv̂(s',w) - v̂(s,w)]∇v̂(s,w)",
              "actor_update": "θ ← θ + β ∇ ln π(a|s,θ) [R + γv̂(s',w) - v̂(s,w)]",
              "advantage": "Online learning, lower variance"
            },
            {
              "name": "Natural Gradient",
              "idea": "Use Fisher Information metric",
              "update": "θ ← θ + α F^(-1) ∇J(θ)",
              "advantage": "More efficient convergence"
            },
            {
              "name": "PPO (Proximal Policy Optimization)",
              "idea": "Limit policy change per update via clipping",
              "advantage": "Prevents huge updates, stable training"
            },
            {
              "name": "TRPO (Trust Region Policy Optimization)",
              "idea": "Limit policy change via KL divergence constraint",
              "advantage": "Principled policy update constraints"
            }
          ]
        }
      ]
    }
  ],
  "algorithms": {
    "tabular_methods": [
      {
        "name": "Dynamic Programming Value Iteration",
        "type": "On-policy",
        "requires_model": true,
        "formula": "V(s) ← max_a E[r + γV(s')]",
        "convergence": "Guaranteed to v_*"
      },
      {
        "name": "MC Control",
        "type": "On-policy",
        "requires_model": false,
        "formula": "Q(s,a) ← Q(s,a) + α(G - Q(s,a))",
        "convergence": "Guaranteed with exploring starts"
      },
      {
        "name": "Sarsa",
        "type": "On-policy",
        "requires_model": false,
        "formula": "Q(s,a) ← Q(s,a) + α(r + γQ(s',a') - Q(s,a))",
        "convergence": "Converges to optimal with ε-greedy"
      },
      {
        "name": "Q-Learning",
        "type": "Off-policy",
        "requires_model": false,
        "formula": "Q(s,a) ← Q(s,a) + α(r + γ max_a' Q(s',a') - Q(s,a))",
        "convergence": "Guaranteed to q_*"
      },
      {
        "name": "TD(λ)",
        "type": "On-policy",
        "requires_model": false,
        "formula": "e ← λγe + ∇V(s); w ← w + αδe",
        "convergence": "Depends on λ"
      }
    ],
    "function_approximation_methods": [
      {
        "name": "Semi-Gradient TD(0)",
        "formula": "w ← w + α(r + γv̂(s',w) - v̂(s,w))∇v̂(s,w)",
        "stability": "Less stable off-policy"
      },
      {
        "name": "REINFORCE",
        "formula": "θ ← θ + α∇ln π(a|s,θ)(G - b)",
        "variance": "High, but unbiased"
      },
      {
        "name": "Actor-Critic",
        "formula": "θ ← θ + α∇ln π(a|s,θ)(r + γv̂(s',w) - v̂(s,w))",
        "variance": "Lower than REINFORCE"
      }
    ]
  },
  "key_concepts": {
    "exploration_exploitation": {
      "definition": "Balance between trying new actions (explore) vs using best known (exploit)",
      "methods": [
        "ε-greedy: Random with probability ε",
        "UCB: Upper Confidence Bound principle",
        "Thompson Sampling: Bayesian approach",
        "Information Gain: Optimism under uncertainty"
      ]
    },
    "credit_assignment": {
      "definition": "How to assign responsibility for rewards to past actions",
      "challenges": [
        "Immediate reward easy",
        "Sparse reward hard",
        "Delayed reward: which action caused it?"
      ],
      "solutions": [
        "Eligibility traces: decay with time",
        "n-step returns: look multiple steps ahead",
        "Policy gradient: direct gradient through actions"
      ]
    },
    "function_approximation": {
      "definition": "Generalize values across state space using features",
      "types": [
        "Linear: v(s,w) = w^T φ(s)",
        "Non-linear: Neural networks",
        "Local: RBF, tile coding"
      ],
      "challenges": [
        "Bias: may not represent true value",
        "Variance: depends on features",
        "Deadly triad: FA + bootstrapping + off-policy"
      ]
    },
    "deadly_triad": {
      "components": [
        "Function Approximation",
        "Bootstrapping",
        "Off-Policy"
      ],
      "problem": "Can cause divergence",
      "solutions": [
        "Prioritized Experience Replay",
        "Target networks",
        "Importance sampling",
        "Gradient TD"
      ]
    }
  },
  "notation": {
    "state": "s, S_t",
    "action": "a, A_t",
    "reward": "r, R_t (immediate), G_t (cumulative)",
    "return": "G_t = Σ γ^k R_{t+k+1}",
    "value_state": "v(s) - expected return from state",
    "value_action": "q(s,a) - expected return from state-action",
    "policy": "π(a|s) - probability of action a in state s",
    "discount_factor": "γ (0 ≤ γ ≤ 1)",
    "learning_rate": "α (0 < α ≤ 1)",
    "trace_decay": "λ (0 ≤ λ ≤ 1)",
    "td_error": "δ_t = R_{t+1} + γV(S_{t+1}) - V(S_t)",
    "eligibility_trace": "e(s) - decay with γλ",
    "parameters": "θ (policy), w (value function)",
    "gradient": "∇ - derivative with respect to parameters"
  },
